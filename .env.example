# Required: get from https://console.upstage.ai/api-keys
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the synth model (default: solar-pro2)
# UPSTAGE_SYNTH_MODEL=solar-pro2

# Optional: only needed for notion_sync.py
# Get from https://www.notion.so/my-integrations
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# Notion DB id where the use-case set should land (32-char hex with dashes)
# NOTION_LIBRARY_DB_ID=11111111-1111-1111-1111-111111111111
